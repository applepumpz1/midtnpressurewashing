<title>MidTN Pressure Washing</title>

<style>
body {
    font-family: Arial;
    margin:0;
    background:#f4f4f4;
}

.hero {
background:url('https://images.unsplash.com/photo-1568605114967-8130f3a36994') center/cover;
color:white;
text-align:center;
padding:80px 20px;
}

.hero h1 {font-size:40px;}
.hero p {font-size:18px;}

.hero a {
display:inline-block;
margin:10px;
padding:12px 20px;
background:#38ada9;
color:white;
text-decoration:none;
border-radius:5px;
}

section {
padding:30px;
background:white;
margin:20px;
border-radius:10px;
}

.images {
display:flex;
flex-wrap:wrap;
gap:15px;
}

.images img {
width:100%;
max-width:300px;
border-radius:10px;
}

.flyer {
text-align:center;
}

.flyer img {
width:100%;
max-width:500px;
border-radius:10px;
box-shadow:0 4px 10px rgba(0,0,0,0.2);
}

form input, textarea {
width:100%;
padding:10px;
margin-top:10px;
}

button {
padding:12px;
background:#0a3d62;
color:white;
border:none;
}

.sticky {
position:fixed;
bottom:0;
width:100%;
background:#0a3d62;
text-align:center;
padding:10px;
}

.sticky a {
color:white;
margin:10px;
text-decoration:none;
}
</style>
</head>

